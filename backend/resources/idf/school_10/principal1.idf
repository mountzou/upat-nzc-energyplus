! Principal1_Office West wall (X = 0) – faces negative X, splitted into 2 segments 
!Lower exterior part
Wall:Detailed,
  Wall1_West_Lower,              !- Name
  Insulated_Brick_Wall,          !- Construction Name
  Principal1_Office,             !- Zone Name
  ,                              !- Space Name
  Adiabatic,                     !- Outside Boundary Condition
