  21.44,0.00,0.0,                !- V2 lower-left
  21.44,10.74,0.0,               !- V3 lower-right
  21.44,10.74,3.0;               !- V4 upper-right

! North wall (Y = 10.74) – faces positive Y
Wall:Detailed,
  Wall_North,                    !- Name
  Insulated_Brick_Wall,          !- Construction Name
  Event_Hall,                    !- Zone Name
  ,                              !- Space Name
  Outdoors,                      !- Outside Boundary Condition
  ,                              !- Outside Boundary Condition Object
  SunExposed,                    !- Sun Exposure
  WindExposed,                   !- Wind Exposure
  0.5,                           !- View Factor to Ground
  4,                             !- Number of Vertices
  0,10.74,3.0,                   !- V1 upper-left (UL)
  21.44,10.74,3.0,               !- V2 upper-right (UR)
  21.44,10.74,0.0,               !- V3 lower-right (LR)
  0,10.74,0.0;                   !- V4 lower-left (LL)

! West wall (X = 0) – faces negative X
Wall:Detailed,
  Wall_West,                     !- Name
  Insulated_Brick_Wall,          !- Construction Name
  Event_Hall,                    !- Zone Name
  ,                              !- Space Name
  Adiabatic,                     !- Outside Boundary Condition
  ,                              !- Outside Boundary Condition Object
  NoSun,                         !- Sun Exposure
  NoWind,                        !- Wind Exposure
  0.5,                           !- View Factor to Ground
  4,                             !- Number of Vertices
  0,10.74,3.0,                   !- V1 upper-left (UL)
  0,10.74,0.0,                   !- V2 upper-right (UR)
  0,0,0.0,                       !- V3 lower-right (LR)
  0,0,3.0;                       !- V4 lower-left (LL)

!Window layer 1
WindowMaterial:Glazing,
  Glass_LowE_4mm,        !- Name
  SpectralAverage,       !- Optical Data Type
  ,                      !- Window Glass Spectral Data Set Name
  0.004,                 !- Thickness {m}
  0.84,                  !- Solar Transmittance at Normal Incidence
  0.04,                  !- Front Side Solar Reflectance at Normal Incidence
  0.04,                  !- Back Side Solar Reflectance at Normal Incidence
  0.78,                  !- Visible Transmittance at Normal Incidence
  0.10,                  !- Front Side Visible Reflectance at Normal Incidence
  0.10,                  !- Back Side Visible Reflectance at Normal Incidence
  0.04,                  !- Infrared Transmittance
  0.84,                  !- Front Side Infrared Hemispherical Emissivity
  0.84,                  !- Back Side Infrared Hemispherical Emissivity
  1.0;                   !- Conductivity {W/m-K}

!Window layer 2 
WindowMaterial:Gas,
  Argon_16mm,            !- Name
  Argon,                 !- Gas Type
  0.016;                 !- Thickness {m}

!Window layer 3
WindowMaterial:Glazing,
  Glass_Clear_4mm,
  SpectralAverage,
  ,
  0.004,
  0.84,
  0.075,
  0.075,
  0.89,
  0.08,
  0.08,
  0.0,
  0.84,
  0.84,
  1.0;

!Window construction
Construction,
  Window_Double_LowE_Argon,   !- Name
  Glass_LowE_4mm,
  Argon_16mm,
  Glass_Clear_4mm;

