    HW-Demand-R2-Out,                     !- Outlet Node Name
    HeatingDesignCapacity,                !- Heating Design Capacity Method
    5000,                                 !- Heating Design Capacity {W}
    ,                                     !- Heating Design Capacity Per Floor Area {W/m2}
    ,                                     !- Fraction of Autosized Heating Design Capacity
    110,                                  !- U-Factor Times Area Value {W/K}
    0.00007,                              !- Maximum Water Flow Rate {m3/s}
    0.001;                                !- Convergence Tolerance

PlantEquipmentOperationSchemes,
    HW-Loop-Operation,              !- Name
    PlantEquipmentOperation:HeatingLoad,  !- Control Scheme 1 Object Type
    HW-Heating-Operation,           !- Control Scheme 1 Name
    HW-Heating-Schedule;            !- Control Scheme 1 Schedule Name

PlantEquipmentOperation:HeatingLoad,
    HW-Heating-Operation,           !- Name
    0, 1e9,                         !- Load Range 1 Lower/Upper Limit {W}
    HW-Boiler-EquipmentList;        !- Range 1 Equipment List Name

PlantEquipmentList,
    HW-Boiler-EquipmentList,
    Boiler:HotWater,
    HW-Boiler;

PlantLoop,                                ! The “container” for all heating components:  pump, boiler, radiator, pipes, connectors, temperature control.
  HW-Loop,                                !- Name
  Water,                                  !- Fluid Type
  ,                                       !- User Defined Fluid Type
  HW-Loop-Operation,                      !- Plant Equipment Operation Scheme List Name
  HW-SupplyOutlet,                        !- Loop Temperature Setpoint Node Name  <<< FIX (must NOT be blank)
  90.0,                                   !- Maximum Loop Temperature {C}
  10.0,                                   !- Minimum Loop Temperature {C}
  0.0004,                                 !- Maximum Loop Flow Rate {m3/s}
  0.0,                                    !- Minimum Loop Flow Rate {m3/s}
  0.1,                                    !- Plant Loop Volume {m3}
  HW-SupplyInlet,                         !- Plant Side Inlet Node Name
  HW-SupplyOutlet,                        !- Plant Side Outlet Node Name
  HW-Loop-Supply Branches,                !- Plant Side Branch List Name
  ,                                       !- Plant Side Connector List Name
  HW-Loop-DemandInlet,                    !- Demand Side Inlet Node Name
  HW-Loop-DemandOutlet,                   !- Demand Side Outlet Node Name
  HW-Loop-Demand Branches,                !- Demand Side Branch List Name
  HW-Loop-Demand Connectors,              !- Demand Side Connector List Name
  Optimal;                                !- Load Distribution Scheme

Pipe:Adiabatic,
  HW-Supply Outlet Pipe,
  HW-Boiler-Outlet,                       !- Inlet Node Name
  HW-SupplyOutlet;                        !- Outlet Node Name

Pump:ConstantSpeed,           ! Moves water through the heating loop. Without it, water does not cirCRlate → no heating 
    HW-Pump,                  !- Name
    HW-SupplyInlet,           !- Inlet Node Name
    HW-SupplyPumpOutlet,      !- Outlet Node Name
    0.0004,                   !- Rated Flow Rate {m3/s}
    50000,                    !- Rated Pump Head {Pa}
    25,                       !- Rated Power Consumption {W}
    0.9,                      !- Motor Efficiency
    0.0,                      !- Fraction of Motor Inefficiencies to Fluid Stream
    INTERMITTENT;             !- Pump Control Type

Boiler:HotWater,                   ! Provides hot water for radiators. Automatically sizes capacity
    HW-Boiler,                     !- Name
    Diesel,                        !- Fuel Type
    Autosize,                      !- Nominal Capacity {W}
    0.8,                           !- Nominal Thermal Efficiency
    LeavingBoiler,                 !- Efficiency Curve Temperature Evaluation Variable
    ,                              !- Normalized Boiler Efficiency Curve Name
    0.0004,                        !- Design Water Flow Rate {m3/s}
    0.2,                           !- Minimum Part Load Ratio
    1.0,                           !- Maximum Part Load Ratio
    0.9,                           !- Optimum Part Load Ratio
    HW-SupplyPumpOutlet,           !- Boiler Water Inlet Node Name
    HW-Boiler-Outlet,              !- Boiler Water Outlet Node Name
    100.0,                         !- Water Outlet Upper Temperature Limit {C}
    ConstantFlow,                  !- Boiler Flow Mode
    0.0,                           !- On Cycle Parasitic Electric Load {W}
    1.0;                           !- Sizing Factor

SetpointManager:Scheduled,
    HW-Loop-SetpointManager,
    Temperature,
    HW-Setpoint-Schedule,
    HW-SupplyOutlet;

Schedule:Compact,
    HW-Setpoint-Schedule,
    Temperature,
    Through: 12/31,
    For: AllDays,
      Until: 24:00, 60.0;

!Supply Side
BranchList,                        ! Lists all components on the supply side. 
  HW-Loop-Supply Branches,
  HW-Supply Branch;

Branch,
  HW-Supply Branch,            !- Name of this hydraulic path
  ,
  Pump:ConstantSpeed,          !- Component 1 Object Type
  HW-Pump,                     !- Component 1 Name
  HW-SupplyInlet,              !- Component 1 Inlet Node Name (Water enters the plant loop here)
  HW-SupplyPumpOutlet,         !- Component 1 Outlet Node Name (Pressurized water leaving the pump)
  Boiler:HotWater,             !- Component 2 Object Type
  HW-Boiler,                   !- Component 2 Name
  HW-SupplyPumpOutlet,         !- Component 2 Inlet Node Name (Must match pump outlet node)
  HW-Boiler-Outlet,            !- Component 2 Outlet Node Name (Hot water leaving the boiler)
  Pipe:Adiabatic,              !- Component 3 Object Type
  HW-Supply Outlet Pipe,       !- Component 3 Name
  HW-Boiler-Outlet,            !- Component 3 Inlet Node Name (Must match boiler outlet node)
  HW-SupplyOutlet;             !- Component 3 Outlet Node Name (Supply-side outlet node of the PlantLoop)

!========================
! DEMAND SIDE (4 radiators in parallel)
!========================

BranchList,
  HW-Loop-Demand Branches,
  HW-Demand Inlet Branch,
  HW-Demand Branch CL,
  HW-Demand Branch CR,
  HW-Demand Branch H,
  HW-Demand Branch R2,
  HW-Demand Outlet Branch;

! ---- Demand inlet header (from loop demand inlet -> splitter inlet node)
Branch,
  HW-Demand Inlet Branch,
  ,
  Pipe:Adiabatic,
  HW-Demand Inlet Header Pipe,
  HW-Loop-DemandInlet,
  HW-Demand-Splitter-Inlet-Node;

Pipe:Adiabatic,
  HW-Demand Inlet Header Pipe,
  HW-Loop-DemandInlet,
  HW-Demand-Splitter-Inlet-Node;

! ---- Branch: CL radiator (UNIQUE inlet/outlet nodes)
Branch,
  HW-Demand Branch CL,
  ,
  ZoneHVAC:Baseboard:Convective:Water,
  Radiator_CL,
  HW-Demand-CL-In,
  HW-Demand-CL-Out;

! ---- Branch: CR radiator (UNIQUE inlet/outlet nodes)
Branch,
  HW-Demand Branch CR,
  ,
  ZoneHVAC:Baseboard:Convective:Water,
  Radiator_CR,
  HW-Demand-CR-In,
  HW-Demand-CR-Out;

! ---- Branch: Hallway radiator (UNIQUE inlet/outlet nodes)
Branch,
  HW-Demand Branch H,
  ,
  ZoneHVAC:Baseboard:Convective:Water,
  Radiator_H,
  HW-Demand-H-In,
  HW-Demand-H-Out;

! ---- Branch: Room2 radiator (UNIQUE inlet/outlet nodes)
Branch,
  HW-Demand Branch R2,
  ,
  ZoneHVAC:Baseboard:Convective:Water,
  Radiator_R2,
  HW-Demand-R2-In,
  HW-Demand-R2-Out;

! ---- Demand outlet header (mixer outlet node -> loop demand outlet)
Branch,
  HW-Demand Outlet Branch,
  ,
  Pipe:Adiabatic,
  HW-Demand Outlet Header Pipe,
  HW-Demand-Mixer-Outlet-Node,
  HW-Loop-DemandOutlet;

Pipe:Adiabatic,
  HW-Demand Outlet Header Pipe,
  HW-Demand-Mixer-Outlet-Node,
  HW-Loop-DemandOutlet;

! ---- Connectors (Splitter/Mixer must reference EXISTING branch names above)
ConnectorList,
  HW-Loop-Demand Connectors,
  Connector:Splitter,
  HW-Demand Splitter,
  Connector:Mixer,
  HW-Demand Mixer;

Connector:Splitter,
  HW-Demand Splitter,
  HW-Demand Inlet Branch,
  HW-Demand Branch CL,
  HW-Demand Branch CR,
  HW-Demand Branch H,
  HW-Demand Branch R2;

Connector:Mixer,
  HW-Demand Mixer,
  HW-Demand Outlet Branch,
  HW-Demand Branch CL,
  HW-Demand Branch CR,
  HW-Demand Branch H,
  HW-Demand Branch R2;

!============================================================
! AC Unit
!============================================================

Fan:OnOff,
  Haier_Cab_Fan,
  HVAC-Avail,                  !- Availability Schedule Name
  0.70,                        !- Fan Total Efficiency
  600,                         !- Pressure Rise {Pa}
  0.333,                       !- Maximum Flow Rate {m3/s}
  0.90,                        !- Motor Efficiency
  1.0,                         !- Motor In Airstream Fraction
  Haier_Supply_Inlet,          !- Air Inlet Node Name
  CabAC_After_Fan_Node;        !- Air Outlet Node Name

Coil:Cooling:DX:SingleSpeed,
  Haier_Cab_DX_Cool,                !- Name
  HVAC-Avail,                       !- Availability Schedule Name
  7200,                             !- Gross Rated Total Cooling Capacity {W}
  0.76,                             !- Gross Rated Sensible Heat Ratio
  3.23,                             !- Gross Rated Cooling COP {W/W}
  0.40,                             !- Rated Air Flow Rate {m3/s}
  0.0,                              !- 2017 Rated Evaporator Fan Power Per Volume Flow Rate {W/(m3/s)}
  0.0,                              !- 2023 Rated Evaporator Fan Power Per Volume Flow Rate {W/(m3/s)}
  CabAC_After_Fan_Node,             !- Air Inlet Node Name
  CabAC_After_CoolCoil_Node,        !- Air Outlet Node Name
  Haier_CoolCapFT,                  !- Total Cooling Capacity Function of Temperature Curve Name
  Haier_CoolCapFF,                  !- Total Cooling Capacity Function of Flow Fraction Curve Name
  Haier_CoolEIRFT,                  !- Energy Input Ratio Function of Temperature Curve Name
  Haier_CoolEIRFF,                  !- Energy Input Ratio Function of Flow Fraction Curve Name
  Haier_CoolPLF;                    !- Part Load Fraction Correlation Curve Name

AirLoopHVAC:UnitarySystem,
  Haier_UnitarySystem,                 !- Name
