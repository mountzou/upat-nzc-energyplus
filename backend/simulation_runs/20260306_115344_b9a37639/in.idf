    HW-Demand-CL-In,         !- Inlet Node Name
    HW-Demand-CL-Out,        !- Outlet Node Name
    HeatingDesignCapacity,   !- Heating Design Capacity Method
    10000,                   !- Heating Design Capacity {W}
    ,                        !- Heating Design Capacity Per Floor Area {W/m2}
    ,                        !- Fraction of Autosized Heating Design Capacity
    250,                     !- U-Factor Times Area Value {W/K}
    0.00016,                 !- Maximum Water Flow Rate {m3/s}
    0.001;                   !- Convergence Tolerance

ZoneHVAC:Baseboard:Convective:Water,
    Radiator_CR,                          !- Name
    Heat-Avail,                           !- Availability Schedule Name
    HW-Demand-CR-In,                      !- Inlet Node Name
    HW-Demand-CR-Out,                     !- Outlet Node Name
    HeatingDesignCapacity,                !- Heating Design Capacity Method
    12000,                                !- Heating Design Capacity {W}
    ,                                     !- Heating Design Capacity Per Floor Area {W/m2}
    ,                                     !- Fraction of Autosized Heating Design Capacity
    280,                                  !- U-Factor Times Area Value {W/K}
    0.00020,                              !- Maximum Water Flow Rate {m3/s}
    0.001;                                !- Convergence Tolerance 

ZoneHVAC:Baseboard:Convective:Water,
    Radiator_H,                           !- Name
    HVAC-Avail,                           !- Availability Schedule Name
    HW-Demand-H-In,                       !- Inlet Node Name
    HW-Demand-H-Out,                      !- Outlet Node Name
    HeatingDesignCapacity,                !- Heating Design Capacity Method
    8000,                                 !- Heating Design Capacity {W}
    ,                                     !- Heating Design Capacity Per Floor Area {W/m2}
