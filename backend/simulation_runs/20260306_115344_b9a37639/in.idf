!- ZONES (Ceiling Height = 3m, Ground floor)
!- =========================================================

Zone,
  Classroom_Left,         !- Name
  0,                       !- Direction of Relative North {deg}
  0, 0, 0,                 !- X Origin, Y Origin, Z Origin {m}
